<% title = "Registrar"; %>

<!-- Formulário de registro: cria um usuário com nome/email/senha -->
<section class="form-card">
  <h2>Criar conta</h2>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <form action="/register" method="post" class="book-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Nome</label>
    <input type="text" name="name" value="<%= formData?.name || '' %>">

    <label>Email</label>
    <input type="email" name="email" required value="<%= formData?.email || '' %>">

    <label>Senha</label>
    <input type="password" name="password" required>

    <div class="actions">
      <button class="btn" type="submit">Registrar</button>
      <a class="btn ghost" href="/login">Já tenho conta</a>
    </div>
  </form>
  <% if (googleOAuthEnabled) { %>
    <div class="separator">ou</div>

    <!-- Registro via Google  -->
     <a href="/auth/google" class="google-btn" aria-label="Entrar com Google">
      <img src="https://cdn.simpleicons.org/google/000000" alt="Google" class="google-icon-img">
       Entrar com Google
    </a>
  <% } %>
</section>

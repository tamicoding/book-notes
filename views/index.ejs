<% title = "Meus livros"; %>
<% // `dates` chega do middleware em `index.js` e é usada para popular o filtro lateral %>
<% let datesList = (typeof dates !== 'undefined' && dates) ? dates : []; %>
<% let paginationData = pagination || null; %>
<% let selectedFilter = activeFilter || {}; %>
<% function buildPageHref(pageNumber) {
  const query = new URLSearchParams();
  const sourceQuery = paginationQuery || {};
  Object.keys(sourceQuery).forEach(key => {
    if (sourceQuery[key] !== undefined && sourceQuery[key] !== null && sourceQuery[key] !== '') {
      query.set(key, sourceQuery[key]);
    }
  });
  if (pageNumber > 1) query.set('page', String(pageNumber));
  const queryString = query.toString();
  return `${paginationBasePath || '/'}${queryString ? `?${queryString}` : ''}`;
} %>
<% function getVisiblePages(data) {
  if (!data) return [];
  const totalPages = data.totalPages || 1;
  const currentPage = data.currentPage || 1;
  const pages = new Set([1, totalPages, currentPage, currentPage - 1, currentPage + 1]);
  return [...pages]
    .filter(page => page >= 1 && page <= totalPages)
    .sort((a, b) => a - b);
} %>

<!-- Home: barra do usuário (mobile only) -->

<% if (user) { %>
  <div class="home-userbar mobile-only">
    <div class="home-userbar-center">Olá, <strong><%= user.name %></strong></div>
  </div>
<% } %>

<% if (message) { %>
  <div
    class="alert alert--<%= messageType || 'info' %> page-alert"
    role="status"
    data-auto-dismiss="4500"
  >
    <%= message %>
  </div>
<% } %>

<% if (activeView) { %>
  <section class="view-context view-context--<%= activeView.type || 'all' %>">
    <div class="view-context-copy">
      <span class="view-context-kicker">Explorando agora</span>
      <p class="view-context-label"><%= activeView.label %></p>
      <p class="view-context-description"><%= activeView.description %></p>

      <% if (paginationData) { %>
        <div class="view-context-meta">
          <span class="view-context-chip"><%= paginationData.totalItems %> livro(s)</span>
          <span class="view-context-chip">Página <%= paginationData.currentPage %> de <%= paginationData.totalPages %></span>
        </div>
      <% } %>
    </div>

    <% if ((activeView.type === 'search' || activeView.type === 'date') && paginationBasePath !== '/') { %>
      <a href="/" class="btn ghost small view-context-action">Limpar filtro</a>
    <% } %>
  </section>
<% } %>

<!-- Topo: busca + botão de adicionar livro -->
<div class="top-row">
  <form action="/search" class="search-form" method="get">
    <div class="search-input-wrap">
      <span class="search-icon" aria-hidden="true">⌕</span>
      <input name="q" placeholder="Pesquisar título ou autor" value="<%= search || '' %>">
    </div>
    <button type="submit" class="btn primary">Buscar</button>
  </form>

  <a href="/books/add" class="btn primary add-book">Adicionar livro</a>
</div>

<!-- FILTRO LATERAL -->

<aside class="date-filter" id="dateFilter">
  <div class="date-filter-head">
    <h3>Filtrar por data</h3>
    <button class="icon-btn close-btn mobile-only" type="button" onclick="closeFilterDrawer()" aria-label="Fechar filtros">
      <span class="close-btn-mark" aria-hidden="true"></span>
    </button>
  </div>

  <% // map: {year: {month: [day,day...]}}
    const map = {};
    datesList.forEach(d => {
      const y = String(parseInt(d.year));
      const mNum = parseInt(d.month);
      const dayNum = parseInt(d.day);

      if (!y || Number.isNaN(mNum) || Number.isNaN(dayNum)) return;

      const m = String(mNum).padStart(2,'0');
      const day = String(dayNum).padStart(2,'0');

      if(!map[y]) map[y] = {};
      if(!map[y][m]) map[y][m] = [];
      if(!map[y][m].includes(day)) map[y][m].push(day);
    });

    const years = Object.keys(map).sort((a,b)=>Number(b)-Number(a));
    years.forEach(y=>{
      Object.keys(map[y]).forEach(m=>{
        map[y][m].sort((a,b)=>Number(b)-Number(a));
      });
    });
  %>

  <% if (years.length === 0) { %>
    <div class="muted">Nenhuma data registrada</div>
  <% } %>

  <% years.forEach(year => { 
      const months = Object.keys(map[year]).sort((a,b)=>Number(b)-Number(a));
  %>
    <div class="year-block">
      <button
        class="year-btn <%= selectedFilter.year === year ? 'is-active' : '' %>"
        type="button"
        onclick="toggleYear('<%= year %>')"
      >
        <%= year %>
      </button>

      <div id="year-<%= year %>" class="months <%= selectedFilter.year === year ? '' : 'hidden' %>">
        <% months.forEach(month => { %>
          <button
            class="month-btn <%= selectedFilter.year === year && selectedFilter.month === String(Number(month)) ? 'is-active' : '' %>"
            type="button"
            onclick="toggleMonth('<%= year %>','<%= month %>')"
          >
            <%= new Date(2020, Number(month)-1, 1).toLocaleString('pt-BR', { month: 'long' }) %>
          </button>

          <div
            id="month-<%= year %>-<%= month %>"
            class="days <%= selectedFilter.year === year && selectedFilter.month === String(Number(month)) ? '' : 'hidden' %>"
          >
            <% map[year][month].forEach(day => { %>
              <a
                class="day-link <%= selectedFilter.year === year && selectedFilter.month === String(Number(month)) && selectedFilter.day === String(Number(day)) ? 'is-active' : '' %>"
                href="/filter/date/<%= year %>/<%= Number(month) %>/<%= Number(day) %>"
              >
                <%= day %>/<%= month %>/<%= year %>
              </a>
            <% }) %>
          </div>
        <% }) %>

        <a
          href="/filter/date/<%= year %>"
          class="month-link month-all <%= selectedFilter.year === year && !selectedFilter.month ? 'is-active' : '' %>"
        >
          Ver todos de <%= year %>
        </a>
      </div>
    </div>
  <% }) %>

  <div class="mobile-only" style="margin-top:14px;">
    <!-- Botão de logout mobile only dentro do drawer -->
    <form action="/logout" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn danger full" type="submit">Sair</button>
    </form>
  </div>
</aside>

<script>
  function toggleYear(year){
    const el = document.getElementById("year-" + year);
    if(!el) return;
    el.classList.toggle("hidden");

    if(el.classList.contains("hidden")){
      document.querySelectorAll(`[id^="month-${year}-"]`).forEach(m => m.classList.add("hidden"));
    }
  }

  function toggleMonth(year, month){
    const el = document.getElementById(`month-${year}-${month}`);
    if(!el) return;
    el.classList.toggle("hidden");
  }

  function closeFilterDrawer(){
    const filter = document.getElementById("dateFilter");
    const overlay = document.getElementById("overlay");
    filter?.classList.remove("open");
    overlay?.classList.remove("open");
    document.body.classList.remove("no-scroll");
  }
</script>

<section class="books-grid">
  <% if (!books || books.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon" aria-hidden="true">📚</div>
      <h2>Sua estante ainda está vazia</h2>
      <p>Adicione seu primeiro livro para começar a acompanhar leituras, notas e avaliações.</p>
      <a href="/books/add" class="btn primary">Adicionar primeiro livro</a>
    </div>
  <% } %>

  <% books.forEach(book => { %>
    <article class="card">

      <div class="cover-wrap">
        <% if (book.manual_cover_url || book.cover_url) { %>
          <img src="<%= book.manual_cover_url || book.cover_url %>" alt="Capa de <%= book.title %>">
        <% } else { %>
          <div class="cover-placeholder">
            <span class="cover-placeholder-icon" aria-hidden="true">✦</span>
            <span class="cover-placeholder-text">Sem capa</span>
          </div>
        <% } %>
      </div>

      <div class="card-body">
        <h3><%= book.title %></h3>
        <p class="card-author">por <%= book.author || 'Autor não informado' %></p>

        <div class="card-meta">
          <% if (book.rating) { %>
            <p class="rating">
              <%
                const fullStars = '★★★★★';
                const emptyStars = '☆☆☆☆☆';
              %>
              <span class="stars <%= book.rating >= 3 ? 'stars--good' : 'stars--bad' %>">
                <%= fullStars.slice(0, book.rating) + emptyStars.slice(book.rating) %>
              </span>
            </p>
          <% } %>

          <% if (book.read_date) { %>
            <p class="card-date">
              Lido em
              <strong><%= new Date(book.read_date).toLocaleDateString("pt-BR") %></strong>
            </p>
          <% } %>
        </div>

        <p class="notes"><%= book.notes || "Sem notas" %></p>
      </div>

      <div class="card-actions">
        <a class="btn small card-edit" href="/books/edit/<%= book.id %>">Editar</a>
        <a class="btn small danger" href="/books/delete/<%= book.id %>">Excluir</a>
      </div>

    </article>
  <% }) %>
</section>

<% if (paginationData && paginationData.totalItems > paginationData.pageSize) { %>
  <nav class="pagination" aria-label="Paginação de livros">
    <div class="pagination-status">
      <strong>Página <%= paginationData.currentPage %></strong>
      <span>de <%= paginationData.totalPages %></span>
      <small><%= paginationData.totalItems %> livro(s)</small>
    </div>

    <div class="pagination-controls">
      <a
        class="btn ghost small pagination-nav <%= paginationData.hasPreviousPage ? '' : 'is-disabled' %>"
        href="<%= paginationData.hasPreviousPage ? buildPageHref(paginationData.currentPage - 1) : '#' %>"
        aria-disabled="<%= paginationData.hasPreviousPage ? 'false' : 'true' %>"
      >
        Anterior
      </a>

      <div class="pagination-pages" aria-label="Páginas disponíveis">
        <% const visiblePages = getVisiblePages(paginationData); %>
        <% visiblePages.forEach((pageNumber, index) => { %>
          <% const previousPage = visiblePages[index - 1]; %>
          <% if (index > 0 && pageNumber - previousPage > 1) { %>
            <span class="pagination-ellipsis" aria-hidden="true">...</span>
          <% } %>

          <% if (pageNumber === paginationData.currentPage) { %>
            <span class="pagination-page is-current" aria-current="page"><%= pageNumber %></span>
          <% } else { %>
            <a class="pagination-page" href="<%= buildPageHref(pageNumber) %>"><%= pageNumber %></a>
          <% } %>
        <% }) %>
      </div>

      <a
        class="btn ghost small pagination-nav <%= paginationData.hasNextPage ? '' : 'is-disabled' %>"
        href="<%= paginationData.hasNextPage ? buildPageHref(paginationData.currentPage + 1) : '#' %>"
        aria-disabled="<%= paginationData.hasNextPage ? 'false' : 'true' %>"
      >
        Próxima
      </a>
    </div>
  </nav>
<% } %>
